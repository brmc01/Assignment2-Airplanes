{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Run Assignment (show results)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Run Assignment (no popups, just save files)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "args": ["--no-show", "--no-open"],
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Rebuild Documentation.pdf",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/make_docs.py",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}
